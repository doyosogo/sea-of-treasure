# PostgreSQL connection string used by Prisma.
# Local example format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sea_of_treasure?schema=public"

# Secret used to sign short-lived access tokens. Use a long random value.
JWT_ACCESS_SECRET="replace-with-a-long-random-access-secret"

# Secret used to sign refresh tokens. Use a different long random value.
JWT_REFRESH_SECRET="replace-with-a-long-random-refresh-secret"

# Port for the Express API server.
PORT=3001

# Browser origin allowed by CORS during local frontend development.
CLIENT_ORIGIN="http://localhost:5173"
